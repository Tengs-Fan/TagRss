<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>TagRSS Feeds</title>
  </head>
  <body>
    <!-- Tech Sources -->
    <outline type="rss"
             text="Hacker News"
             xmlUrl="https://hnrss.org/frontpage"
             htmlUrl="https://news.ycombinator.com"
             tags="tech,news,important" />

    <outline type="rss"
             text="Ars Technica"
             xmlUrl="https://feeds.arstechnica.com/arstechnica/technology-lab"
             htmlUrl="https://arstechnica.com"
             tags="tech,news" />

    <outline type="rss"
             text="Lobsters"
             xmlUrl="https://lobste.rs/rss"
             htmlUrl="https://lobste.rs"
             tags="tech/programming,important" />

    <!-- AI Sources -->
    <outline type="rss"
             text="OpenAI Blog"
             xmlUrl="https://openai.com/blog/rss.xml"
             htmlUrl="https://openai.com/blog"
             tags="tech/ai/llm,important" />

    <outline type="rss"
             text="AI News - MIT"
             xmlUrl="https://news.mit.edu/topic/mitartificial-intelligence2-rss.xml"
             htmlUrl="https://news.mit.edu/topic/artificial-intelligence2"
             tags="tech/ai,science" />

    <!-- Science -->
    <outline type="rss"
             text="Quanta Magazine"
             xmlUrl="https://www.quantamagazine.org/feed"
             htmlUrl="https://www.quantamagazine.org"
             tags="science,important" />

    <!-- News -->
    <outline type="rss"
             text="BBC World"
             xmlUrl="https://feeds.bbci.co.uk/news/world/rss.xml"
             htmlUrl="https://www.bbc.com/news/world"
             tags="news/world" />

    <outline type="rss"
             text="NYT Technology"
             xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml"
             htmlUrl="https://www.nytimes.com/section/technology"
             tags="tech,news" />

    <!-- Life -->
    <outline type="rss"
             text="Serious Eats"
             xmlUrl="https://www.seriouseats.com/feeds/serious-eats"
             htmlUrl="https://www.seriouseats.com"
             tags="life/cooking" />

    <outline type="rss"
             text="Brain Pickings"
             xmlUrl="https://www.themarginalian.org/feed/"
             htmlUrl="https://www.themarginalian.org"
             tags="life/reading,important" />
  </body>
</opml>
